# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# PostgreSQL Database
DB_HOST=192.168.0.61
DB_PORT=5432
DB_NAME=yapi
DB_USER=postgres
DB_PASSWORD=123456

# Security - JWT
JWT_SECRET=your-secret-key-change-this-to-random-64-char-string
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=your-refresh-secret-change-this-to-random-64-char-string
REFRESH_TOKEN_EXPIRY=7d

# Security - Encryption (for database credentials)
ENCRYPTION_KEY=your-encryption-key-change-this-to-random-64-char-string
ENCRYPTION_SALT=your-salt-change-this-to-random-32-char-string

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000
ADMIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
# In Development: Leave commented out or empty to allow ALL origins (easiest for local dev)
# In Production: You MUST set this to your frontend domain to block other sites
# Single domain example:
# CORS_ORIGIN=https://admin.yapi.com
# Multiple domains example:
# CORS_ORIGIN=https://admin.yapi.com,https://app.yapi.com
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
